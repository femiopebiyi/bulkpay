  "db_name": "PostgreSQL",
  "query": "UPDATE contacts\n         SET name        = COALESCE($1, name),\n             email       = COALESCE($2, email),\n             description = COALESCE($3, description),\n             notes       = COALESCE($4, notes),\n             updated_at  = now()\n         WHERE id = $5\n           AND owner_pubkey = $6\n         RETURNING id, wallet_pubkey, name, email, description, notes",
