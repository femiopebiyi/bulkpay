{
  "name": "@bulkpay/program",
  "license": "ISC",
  "scripts": {
    "lint:fix": "prettier */*.js \"*/**/*{.js,.ts}\" -w",
    "lint": "prettier */*.js \"*/**/*{.js,.ts}\" --check",
    "test": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 'tests/**/*.test.ts'",
    "test:create-account": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 'tests/create_account.test.ts'",
    "test:init-log": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 'tests/init_transfer_log.test.ts'",
    "test:bulk-suite": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 'tests/bulk_transfer/*.test.ts'",
    "test:account-suite": "yarn run ts-mocha -p ./tsconfig.json -t 1000000 'tests/create_account.test.ts' 'tests/init_transfer_log.test.ts'"
  },
  "dependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/spl-token": "^0.4.14"
  },
  "devDependencies": {
    "@types/bn.js": "^5.1.0",
    "@types/chai": "^4.3.0",
    "@types/mocha": "^9.0.0",
    "chai": "^4.3.4",
    "mocha": "^9.0.3",
    "prettier": "^2.6.2",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.7.3"
  }
}
